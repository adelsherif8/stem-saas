APP_NAME=Stem SaaS
ENVIRONMENT=development

# Local quickstart uses SQLite; docker-compose overrides this with Postgres.
DATABASE_URL=sqlite:///./stemsaas.db
REDIS_URL=redis://localhost:6379/0

# Set CELERY_EAGER=true to run jobs synchronously without a Redis broker
# (great for a quick `uvicorn`-only demo or tests).
CELERY_EAGER=false

JWT_SECRET=dev-secret-change-me-to-a-long-random-value-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440

STORAGE_DIR=./storage

# Set DEMUCS_REAL=true to run real HT-Demucs (requires `pip install demucs`).
DEMUCS_REAL=false

FREE_TIER_MONTHLY_LIMIT=3
PRO_PRICE_USD=9.0
